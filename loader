local KEY_FILE = "roninhub_key.txt"
local SCRIPT_URL = "https://raw.githubusercontent.com/Ronin-Studios/Ronin-Hub/refs/heads/main/Grow-A-Garden-2"
local WORK_INK_LINK = "https://work.ink/2DE4/ronin-hub-key-system"
local VALIDATE_URL = "https://work.ink/_api/v2/token/isValid/"

local function SaveKey(key)
    if writefile then pcall(writefile, KEY_FILE, key) end
end

local function LoadSavedKey()
    if isfile and readfile and isfile(KEY_FILE) then
        local ok, val = pcall(readfile, KEY_FILE)
        if ok and val and val:gsub("%s+", "") ~= "" then
            return val:gsub("%s+", "")
        end
    end
    return nil
end

local function ValidateKey(key)
    if not key or key == "" then return false end
    local ok, result = pcall(function()
        return game:HttpGet(VALIDATE_URL .. key, true)
    end)
    if not ok or not result then return false end
    local parseOk, data = pcall(function()
        return HttpService:JSONDecode(result)
    end)
    return parseOk and data and data.valid == true
end

local function LoadMainScript()
    pcall(function()
        loadstring(game:HttpGet(SCRIPT_URL, true))()
    end)
end

local savedKey = LoadSavedKey()
if savedKey and ValidateKey(savedKey) then
    LoadMainScript()
    return
end

